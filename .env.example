# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://dro:dro_pass@postgres:5432/dro_db

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Data paths (inside container)
PATH_CONNECTOME=/app/data/connections.parquet
PATH_COMPLETENESS=/app/data/completeness.csv
RESULTS_DIR=/app/data/results

# CORS (your domain)
CORS_ORIGINS=["http://localhost","http://localhost:3000","https://yourdomain.com"]
